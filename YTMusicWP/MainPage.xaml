                            <StackPanel>
                                <FontIcon x:Name="ShuffleIcon" FontFamily="Segoe UI Symbol" Glyph="&#xE14B;" Foreground="White" FontSize="20"/>
                                <Ellipse x:Name="ShuffleDot" Width="4" Height="4" Fill="#1DB954" Margin="0,3,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Click="PrevButton_Click" Style="{StaticResource IconButtonStyle}">
                            <FontIcon FontFamily="Segoe UI Symbol" Glyph="&#xE100;" Foreground="White" FontSize="24"/>
                        </Button>
                        <Button Grid.Column="2" Click="PlayPauseButton_Click" Style="{StaticResource IconButtonStyle}" Width="64" Height="64" Margin="5,0,5,0">
                            <Border Background="#1DB954" CornerRadius="32" Width="64" Height="64">
                                <SymbolIcon x:Name="BigPlayIcon" Symbol="Play" Foreground="Black"/>
                            </Border>
                        </Button>
                        <Button Grid.Column="3" Click="NextButton_Click" Style="{StaticResource IconButtonStyle}">
                            <FontIcon FontFamily="Segoe UI Symbol" Glyph="&#xE101;" Foreground="White" FontSize="24"/>
                        </Button>
                        <Button Grid.Column="4" Click="RepeatButton_Click" Style="{StaticResource IconButtonStyle}">
                            <StackPanel>
                                <FontIcon x:Name="RepeatIcon" FontFamily="Segoe UI Symbol" Glyph="&#xE1CD;" Foreground="White" FontSize="20"/>
                                <Ellipse x:Name="RepeatDot" Width="4" Height="4" Fill="#1DB954" Margin="0,3,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════ FULLSCREEN LYRICS ═══════════════════════════════════ -->
        <Grid x:Name="FullscreenLyricsView" Visibility="Collapsed" Canvas.ZIndex="120" Grid.RowSpan="3" Tapped="CloseFullscreenLyrics_Tapped">
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop x:Name="FullscreenLyricsGradientTop" Color="#1A1A2E" Offset="0"/>
                        <GradientStop Color="#0A0A0A" Offset="0.5"/>
                        <GradientStop Color="#121212" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Grid Margin="20,60,20,80">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Song info at top -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock x:Name="FullscreenLyricsTitle" Text="" FontSize="20" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" Foreground="White" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="FullscreenLyricsArtist" Text="" FontSize="14" Foreground="#B3B3B3" TextAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <!-- Lyrics content -->
                <ListView x:Name="FullscreenLyricsListView" Grid.Row="1" SelectionMode="None" ShowsScrollingPlaceholders="False" ContainerContentChanging="FullscreenLyricsListView_ContainerContentChanging">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}" FontSize="22" Foreground="{Binding ColorBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="5,12" FontWeight="Bold" FontFamily="{StaticResource MontserratBold}" HorizontalAlignment="Center"/>
