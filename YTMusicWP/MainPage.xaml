                        <TextBox x:Name="ClientIdTextBox" PlaceholderText="Client ID..." Style="{StaticResource DarkTextBoxStyle}"/>
                    </Border>
                    <Border Background="#1E1E1E" CornerRadius="10" Margin="0,0,0,15">
                        <TextBox x:Name="ClientSecretTextBox" PlaceholderText="Client Secret..." Style="{StaticResource DarkTextBoxStyle}"/>
                    </Border>
                    <TextBlock Text="Click Login to sign in with your Google account." Foreground="#B3B3B3" FontSize="12" Margin="5,0,0,15" TextWrapping="Wrap"/>
                    <Button Click="LoginGoogle_Click" Style="{StaticResource CategoryButtonStyle}" Margin="0,0,0,25" Height="50">
                        <Border Background="#1DB954" CornerRadius="8">
                            <TextBlock Text="Login with Google" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" FontSize="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Button>
                    <TextBlock x:Name="LoginStatusText" Text="Status: Not Logged In" Foreground="#B3B3B3" FontSize="14" Margin="0,0,0,25" HorizontalAlignment="Center"/>
                    <Button Content="Save Settings" Click="SaveSettingsButton_Click" Background="#1DB954" Foreground="White" FontWeight="Bold" Margin="0,0,0,30" HorizontalAlignment="Stretch" BorderThickness="0" Height="50">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="25">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- ═══════ PLAYBACK SETTINGS ═══════ -->
                    <TextBlock Text="PLAYBACK" Foreground="#B3B3B3" FontSize="14" Margin="5,0,0,5"/>
                    
                    <!-- Audio Quality -->
                    <Grid Margin="5,10,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Audio Quality" Foreground="White" FontSize="16" FontFamily="{StaticResource MontserratSemiBold}"/>
                            <TextBlock Text="Higher quality uses more data" Foreground="#666666" FontSize="12"/>
                        </StackPanel>
                        <ComboBox x:Name="AudioQualityComboBox" Grid.Column="1" Background="#333333" Foreground="White" BorderThickness="0" Width="130" VerticalAlignment="Center">
                            <ComboBoxItem Content="Low (48kbps)" Tag="48"/>
                            <ComboBoxItem Content="Normal (128kbps)" Tag="128"/>
                            <ComboBoxItem Content="High (256kbps)" Tag="256"/>
                        </ComboBox>
                    </Grid>
                    <Rectangle Height="1" Fill="#1E1E1E" Margin="0,0,0,5"/>

                    <!-- Crossfade -->
                    <Grid Margin="5,10,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Crossfade" Foreground="White" FontSize="16" FontFamily="{StaticResource MontserratSemiBold}"/>
                            <TextBlock Text="Smooth transition between songs" Foreground="#666666" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="CrossfadeValueText" Text="0s" Foreground="#1DB954" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider x:Name="CrossfadeSlider" Minimum="0" Maximum="12" StepFrequency="1" Value="0" Width="100"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#1E1E1E" Margin="0,0,0,5"/>

                    <!-- Autoplay -->
                    <Grid Margin="5,10,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Autoplay" Foreground="White" FontSize="16" FontFamily="{StaticResource MontserratSemiBold}"/>
                            <TextBlock Text="Play similar songs when queue ends" Foreground="#666666" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="AutoplayToggle" Grid.Column="1" IsOn="True" OnContent="" OffContent="" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="#1E1E1E" Margin="0,0,0,5"/>

                    <!-- Gapless Playback -->
                    <Grid Margin="5,10,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Gapless Playback" Foreground="White" FontSize="16" FontFamily="{StaticResource MontserratSemiBold}"/>
                            <TextBlock Text="No silence between tracks" Foreground="#666666" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="GaplessToggle" Grid.Column="1" IsOn="True" OnContent="" OffContent="" VerticalAlignment="Center"/>
                    </Grid>
                    <Rectangle Height="1" Fill="#1E1E1E" Margin="0,0,0,5"/>

                    <!-- Normalize Volume -->
                    <Grid Margin="5,10,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Normalize Volume" Foreground="White" FontSize="16" FontFamily="{StaticResource MontserratSemiBold}"/>
                            <TextBlock Text="Set the same volume for all songs" Foreground="#666666" FontSize="12"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="NormalizeVolumeToggle" Grid.Column="1" IsOn="False" OnContent="" OffContent="" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- ═══════ DATA MANAGEMENT ═══════ -->
                    <TextBlock Text="DATA MANAGEMENT" Foreground="#B3B3B3" FontSize="14" Margin="5,0,0,5"/>
                    <Button Click="ClearRecentHistory_Click" Style="{StaticResource CategoryButtonStyle}" Margin="0,0,0,10" Height="45">
                        <Border Background="#8C1932" CornerRadius="8">
                            <TextBlock Text="Clear Recent History" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" FontSize="15" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Button>
                    <Button Click="ClearCache_Click" Style="{StaticResource CategoryButtonStyle}" Margin="0,0,0,10" Height="45">
                        <Border Background="#333333" CornerRadius="8">
                            <TextBlock Text="Clear Image Cache" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" FontSize="15" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Button>
                    <Button Click="LogoutGoogle_Click" Style="{StaticResource CategoryButtonStyle}" Margin="0,0,0,25" Height="45">
                        <Border Background="#333333" CornerRadius="8">
                            <TextBlock Text="Logout Google Account" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" FontSize="15" Foreground="#FF6B6B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Button>

                    <!-- ═══════ ABOUT ═══════ -->
                    <TextBlock Text="ABOUT" Foreground="#B3B3B3" FontSize="14" Margin="5,0,0,5"/>
                    <StackPanel Margin="5,10,0,20">
                        <TextBlock Text="SpotMusic" FontSize="20" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" Foreground="#1DB954"/>
                        <TextBlock Text="Version 1.0.0" FontSize="13" Foreground="#666666" Margin="0,3,0,0"/>
                        <TextBlock Text="A music streaming client for Windows Phone 8.1" FontSize="13" Foreground="#666666" Margin="0,3,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════════════════════ PLAYLIST DETAILS ═══════════════════════════════════ -->
        <Grid x:Name="PlaylistDetailsView" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Canvas.ZIndex="50" Background="#121212">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="PlaylistTransform" Y="1000"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Click="ClosePlaylistDetails_Click" Style="{StaticResource IconButtonStyle}" Width="50" Height="50" Margin="10,15,0,0" HorizontalAlignment="Left">
                <Viewbox Width="20" Height="20"><Path Data="M20,11V13H8L13.5,18.5 12.08,19.92 4.16,12 12.08,4.08 13.5,5.5 8,11H20Z" Fill="White"/></Viewbox>
            </Button>
            <StackPanel Grid.Row="1" Margin="20,0,20,20">
                <Rectangle x:Name="PlaylistDetailsCoverRect" Width="150" Height="150" RadiusX="8" RadiusY="8" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,10">
                    <Rectangle.Fill>
                        <ImageBrush x:Name="PlaylistDetailsCoverBrush" Stretch="UniformToFill">
                            <ImageBrush.RelativeTransform>
                                <ScaleTransform CenterX="0.5" CenterY="0.5" ScaleX="1" ScaleY="1"/>
                            </ImageBrush.RelativeTransform>
                        </ImageBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <TextBlock x:Name="PlaylistDetailsTitle" Text="Playlist Name" FontSize="26" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" Foreground="White" TextAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock x:Name="PlaylistDetailsTrackCount" Text="0 tracks" FontSize="14" Foreground="#B3B3B3" TextAlignment="Center" Margin="0,5,0,0"/>
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="▶ Play All" Click="PlayAllPlaylist_Click" Background="#1DB954" Foreground="Black" FontWeight="Bold" Width="130" Height="45">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="22">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="1" Click="EnhancePlaylist_Click" Style="{StaticResource IconButtonStyle}" Width="45" Height="45" Margin="10,0,0,0">
                        <TextBlock Text="✨" FontSize="22" Foreground="#1DB954"/>
                    </Button>
                    <Button Grid.Column="3" Content="⋮" Foreground="#B3B3B3" FontSize="24" Style="{StaticResource IconButtonStyle}" Width="45" Height="45">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="✖ Delete Playlist" Click="MenuDeletePlaylistInside_Click"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
            </StackPanel>
            <ListView x:Name="PlaylistSongsList" Grid.Row="2" Margin="20,0,20,0" Padding="0" IsItemClickEnabled="True" ItemClick="SongList_ItemClick" SelectionMode="None" ItemTemplate="{StaticResource PlaylistSongItemTemplate}" ItemContainerStyle="{StaticResource StretchItemStyle}" VirtualizingStackPanel.VirtualizationMode="Recycling"/>
        </Grid>

        <!-- ═══════════════════════════════════ MUSIC SHORTS VIEW ═══════════════════════════════════ -->
        <Grid x:Name="ShortsView" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Canvas.ZIndex="55" Background="#0A0A0A"
              ManipulationMode="TranslateX,TranslateY" ManipulationDelta="Shorts_ManipulationDelta" ManipulationCompleted="Shorts_ManipulationCompleted">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ShortsTransform" Y="1000"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Back + Category + Pause -->
            <Grid Grid.Row="0" Margin="0,30,0,0" Canvas.ZIndex="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="ShortsBack_Click" Style="{StaticResource IconButtonStyle}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0" Padding="8">
                    <TextBlock Text="←" FontSize="26" Foreground="White"/>
                </Button>
                <TextBlock x:Name="ShortsCategoryTitle" Grid.Column="1" Text="#edm" FontSize="17" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Click="ShortsPlayCurrent_Click" Style="{StaticResource IconButtonStyle}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0" Padding="8">
                    <TextBlock x:Name="ShortsPauseBtn" Text="❚❚" FontSize="22" Foreground="White"/>
                </Button>
            </Grid>

            <!-- Category Dots -->
            <StackPanel x:Name="ShortsCategoryDots" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,72,0,5">
                <!-- Dots populated dynamically -->
            </StackPanel>

            <!-- Main Content Area -->
            <Grid Grid.Row="1" Margin="0">
                <!-- Blurred background: very low-res image stretched = natural blur -->
                <Grid.Background>
                    <ImageBrush x:Name="ShortsBlurBg" Stretch="UniformToFill" Opacity="0.6"/>
                </Grid.Background>
                <!-- Dark frost overlay on top of blurred bg -->
                <Border Background="#88000000"/>

                <!-- Cover Art (music-only mode) — centered with waveform bars -->
                <Grid x:Name="ShortsCoverArtPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Fake waveform bars left -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-65,0,0,0" Opacity="0.5">
                        <Border Width="4" Height="35" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="55" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="25" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="65" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="40" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="50" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                    </StackPanel>
                    <!-- Cover Art (square album style) -->
                    <Border Width="220" Height="220" CornerRadius="12">
                        <Border.Background>
                            <ImageBrush x:Name="ShortsCoverArt" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                    <!-- Fake waveform bars right -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-65,0" Opacity="0.5">
                        <Border Width="4" Height="45" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="25" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="60" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="35" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="55" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                        <Border Width="4" Height="30" Background="#B3B3B3" CornerRadius="2" Margin="3,0"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Bottom Info Panel -->
            <StackPanel Grid.Row="2" Margin="15,0,15,0">
                <!-- Artist info -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Ellipse x:Name="ShortsArtistAvatar" Width="36" Height="36" VerticalAlignment="Center">
                        <Ellipse.Fill><ImageBrush x:Name="ShortsArtistAvatarBrush" Stretch="UniformToFill"/></Ellipse.Fill>
                    </Ellipse>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="ShortsArtistName" Text="Artist" FontSize="15" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="ShortsArtistSub" Text="" FontSize="11" Foreground="#999999"/>
                    </StackPanel>
                </StackPanel>

                <!-- Hashtags -->
                <StackPanel x:Name="ShortsHashtags" Orientation="Horizontal" Margin="0,0,0,10">
                    <!-- Populated dynamically -->
                </StackPanel>

                <!-- Mini player bar -->
                <Border Background="#2A2A2A" CornerRadius="12" Margin="0,0,0,15" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <!-- Tappable song info → play in main player -->
                        <Grid Grid.Column="0" Tapped="ShortsSongBar_Tapped">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="6">
                                <Border.Background><ImageBrush x:Name="ShortsMiniCover" Stretch="UniformToFill"/></Border.Background>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                <TextBlock x:Name="ShortsSongTitle" Text="Song Title" FontSize="14" FontFamily="{StaticResource MontserratSemiBold}" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="ShortsSongArtist" Text="Artist" FontSize="11" Foreground="#999999" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                        <!-- Heart/Favorite button -->
                        <Button Grid.Column="1" Click="ShortsHeart_Click" Style="{StaticResource IconButtonStyle}" VerticalAlignment="Center">
                            <TextBlock x:Name="ShortsHeartBtn" Text="♡" FontSize="22" Foreground="White"/>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════ ARTIST PROFILE VIEW ═══════════════════════════════════ -->
        <Grid x:Name="ArtistProfileView" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed" Canvas.ZIndex="45" Background="#121212">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ArtistTransform" Y="1000"/>
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Header with cover image -->
            <Grid Grid.Row="0" Height="220">
                <Image x:Name="ArtistProfileCover" Stretch="UniformToFill" Opacity="0.5"/>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00121212" Offset="0.3"/>
                            <GradientStop Color="#121212" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Button Click="CloseArtistProfile_Click" Style="{StaticResource IconButtonStyle}" Width="50" Height="50" Margin="10,15,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Viewbox Width="20" Height="20"><Path Data="M20,11V13H8L13.5,18.5 12.08,19.92 4.16,12 12.08,4.08 13.5,5.5 8,11H20Z" Fill="White"/></Viewbox>
                </Button>
                <StackPanel VerticalAlignment="Bottom" Margin="20,0,20,15">
                    <Ellipse Width="80" Height="80" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="ArtistProfileAvatar" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock x:Name="ArtistProfileTitle" Text="Artist" FontSize="28" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Grid>
            <!-- Action buttons -->
            <Grid Grid.Row="1" Margin="20,10,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="▶ Play" Click="ArtistPlayAll_Click" Background="#1DB954" Foreground="Black" FontWeight="Bold" Width="100" Height="40">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Grid.Column="1" Content="⟳ Shuffle" Click="ArtistShuffle_Click" Foreground="White" FontWeight="SemiBold" Background="#2A2A2A" Width="110" Height="40" Margin="10,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <ProgressBar x:Name="ArtistLoadingBar" Grid.Column="2" IsIndeterminate="True" Visibility="Collapsed" Foreground="#1DB954" VerticalAlignment="Center" Margin="15,0,0,0"/>
            </Grid>
            <!-- Songs + Albums -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,0,30">
                    <ListView x:Name="ArtistSongsList" IsItemClickEnabled="True" ItemClick="SongList_ItemClick" SelectionMode="None" ItemTemplate="{StaticResource SongItemTemplate}" ItemContainerStyle="{StaticResource StretchItemStyle}" VirtualizingStackPanel.VirtualizationMode="Recycling" Margin="10,0,10,0"/>
                    <StackPanel x:Name="ArtistAlbumsSection" Visibility="Collapsed" Margin="10,20,10,0">
                        <TextBlock x:Name="ArtistAlbumsTitle" Text="Albums" FontSize="22" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                        <ListView x:Name="ArtistAlbumsList" IsItemClickEnabled="True" ItemClick="ArtistAlbum_ItemClick" SelectionMode="None" ItemTemplate="{StaticResource ArtistAlbumItemTemplate}" ItemContainerStyle="{StaticResource HorizontalItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollMode="Enabled" ScrollViewer.VerticalScrollMode="Disabled">
                            <ListView.ItemsPanel><ItemsPanelTemplate><VirtualizingStackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ListView.ItemsPanel>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ═══════════════════════════════════ MINI PLAYER (Row 1) ═══════════════════════════════════ -->
        <Grid Grid.Row="1">
            <!-- Mini player green accent top line -->
            <Rectangle Height="2" VerticalAlignment="Top" Canvas.ZIndex="5">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#1DB954" Offset="0"/>
                        <GradientStop Color="#1DB954" Offset="0.5"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Border Background="#181818" Padding="10,8,10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Background="Transparent" Tapped="MiniPlayer_Tapped">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Width="46" Height="46" RadiusX="8" RadiusY="8" Margin="0,0,12,0" VerticalAlignment="Center">
                            <Rectangle.Fill>
                                <ImageBrush x:Name="MiniCoverImage" Stretch="UniformToFill">
                                    <ImageBrush.RelativeTransform>
                                        <ScaleTransform CenterX="0.5" CenterY="0.5" ScaleX="1" ScaleY="1"/>
                                    </ImageBrush.RelativeTransform>
                                </ImageBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock x:Name="MiniTitle" Text="Not playing" FontSize="15" FontFamily="{StaticResource MontserratSemiBold}" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="MiniArtist" Text="Select a song" FontSize="13" Foreground="#B3B3B3" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                    <Button x:Name="MiniPlayPauseBtn" Grid.Column="1" Click="PlayPauseButton_Click" Style="{StaticResource IconButtonStyle}" Width="50">
                        <SymbolIcon x:Name="MiniPlayIcon" Symbol="Play" Foreground="White"/>
                    </Button>
                    <Button Grid.Column="2" Click="NextButton_Click" Style="{StaticResource IconButtonStyle}" Width="50">
                        <FontIcon FontFamily="Segoe UI Symbol" Glyph="&#xE101;" Foreground="White" FontSize="20"/>
                    </Button>
                </Grid>
            </Border>
            <ProgressBar x:Name="MiniProgressBar" VerticalAlignment="Bottom" Height="2" Minimum="0" Maximum="100" Value="0" Foreground="#1DB954" Background="#333333" BorderThickness="0" IsHitTestVisible="False"/>
        </Grid>

        <!-- ═══════════════════════════════════ BOTTOM NAV (Row 2) ═══════════════════════════════════ -->
        <Border Grid.Row="2" Background="#0D0D0D" BorderBrush="#1F1F1F" BorderThickness="0,1,0,0" Padding="0,8,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Home -->
                <Button Grid.Column="0" Click="NavHome_Click" Style="{StaticResource IconButtonStyle}" MinHeight="0">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                            <Path x:Name="NavHomeIcon" Fill="White" Stretch="Uniform" Data="M12,2 L3,10 L3,22 L9,22 L9,16 L15,16 L15,22 L21,22 L21,10 Z"/>
                        </Viewbox>
                        <TextBlock x:Name="NavHomeText" Text="Home" FontSize="10" Foreground="White" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Search -->
                <Button Grid.Column="1" Click="NavSearch_Click" Style="{StaticResource IconButtonStyle}" MinHeight="0">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                            <Path x:Name="NavSearchIcon" Fill="#B3B3B3" Stretch="Uniform" Data="M9.5,2 C5.36,2 2,5.36 2,9.5 C2,13.64 5.36,17 9.5,17 C11.24,17 12.84,16.41 14.12,15.42 L19.35,20.65 L20.65,19.35 L15.42,14.12 C16.41,12.84 17,11.24 17,9.5 C17,5.36 13.64,2 9.5,2 Z M9.5,4.5 C12.26,4.5 14.5,6.74 14.5,9.5 C14.5,12.26 12.26,14.5 9.5,14.5 C6.74,14.5 4.5,12.26 4.5,9.5 C4.5,6.74 6.74,4.5 9.5,4.5 Z"/>
                        </Viewbox>
                        <TextBlock x:Name="NavSearchText" Text="Search" FontSize="10" Foreground="#B3B3B3" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Library -->
                <Button Grid.Column="2" Click="NavLibrary_Click" Style="{StaticResource IconButtonStyle}" MinHeight="0">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                            <Path x:Name="NavLibraryIcon" Fill="#B3B3B3" Stretch="Uniform" Data="M3,21 L3,3 L6,3 L6,21 Z M10,21 L10,3 L13,3 L13,21 Z M17,21 L17,7 L20,7 L20,21 Z"/>
                        </Viewbox>
                        <TextBlock x:Name="NavLibraryText" Text="Library" FontSize="10" Foreground="#B3B3B3" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Create -->
                <Button Grid.Column="3" Click="NavCreate_Click" Style="{StaticResource IconButtonStyle}" MinHeight="0">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="22" Height="22" HorizontalAlignment="Center">
                            <Path x:Name="NavCreateIcon" Fill="#B3B3B3" Stretch="Uniform" Data="M10,2 L14,2 L14,10 L22,10 L22,14 L14,14 L14,22 L10,22 L10,14 L2,14 L2,10 L10,10 Z"/>
                        </Viewbox>
                        <TextBlock x:Name="NavCreateText" Text="Create" FontSize="10" Foreground="#B3B3B3" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════ NOW PLAYING VIEW ═══════════════════════════════════ -->
        <Grid x:Name="NowPlayingView" Visibility="Collapsed" Canvas.ZIndex="100" Grid.RowSpan="3">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="NowPlayingTransform" Y="1000"/>
            </Grid.RenderTransform>
            <!-- Gradient background (genre-based color) -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush x:Name="NowPlayingGradient" StartPoint="0,0" EndPoint="0,1">
                        <GradientStop x:Name="NowPlayingGradientTop" Color="#1A1A2E" Offset="0"/>
                        <GradientStop Color="#121212" Offset="0.6"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
            <Grid Canvas.ZIndex="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,20,0,0" Height="70">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Click="CloseNowPlaying_Click" Style="{StaticResource IconButtonStyle}" Background="#01000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Viewbox Width="22" Height="22"><Path Data="M7.41,8.58L12,13.17 16.59,8.58 18,10 12,16 6,10Z" Fill="White"/></Viewbox>
                    </Button>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="NOW PLAYING" FontSize="11" FontFamily="{StaticResource MontserratSemiBold}" FontWeight="SemiBold" Foreground="#AAFFFFFF" CharacterSpacing="150" HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Ellipse x:Name="DotPlayer" Width="7" Height="7" Fill="#1DB954" Margin="0,0,4,0" Opacity="1.0"/>
                            <Ellipse x:Name="DotLyrics" Width="7" Height="7" Fill="White" Margin="4,0,4,0" Opacity="0.3"/>
                            <Ellipse x:Name="DotQueue" Width="7" Height="7" Fill="White" Margin="4,0,0,0" Opacity="0.3"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Click="OpenNowPlayingMenu_Click" Style="{StaticResource IconButtonStyle}" Background="#01000000" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Viewbox Width="22" Height="22"><Path Data="M12,16A2,2 0 0,1 10,14A2,2 0 0,1 12,12A2,2 0 0,1 14,14A2,2 0 0,1 12,16M12,10A2,2 0 0,1 10,8A2,2 0 0,1 12,6A2,2 0 0,1 14,8A2,2 0 0,1 12,10M12,22A2,2 0 0,1 10,20A2,2 0 0,1 12,18A2,2 0 0,1 14,20A2,2 0 0,1 12,22Z" Fill="White"/></Viewbox>
                    </Button>
                </Grid>
                <Pivot x:Name="NowPlayingPivot" Grid.Row="1" Foreground="White" Margin="0,10,0,0" SelectionChanged="NowPlayingPivot_SelectionChanged">
                    <Pivot.HeaderTemplate>
                        <DataTemplate><Grid Height="0" Visibility="Collapsed"/></DataTemplate>
                    </Pivot.HeaderTemplate>
                    <Pivot.ItemContainerStyle>
                        <Style TargetType="PivotItem"><Setter Property="Margin" Value="0"/></Style>
                    </Pivot.ItemContainerStyle>
                    <!-- Player page -->
                    <PivotItem>
                        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-10,0,0">
                            <!-- Shadow effect -->
                            <Rectangle Width="290" Height="290" RadiusX="16" RadiusY="16" Fill="#40000000" Margin="10,10,0,0"/>
                            <!-- Album art -->
                            <Rectangle Width="300" Height="300" RadiusX="16" RadiusY="16" RenderTransformOrigin="0.5,0.5">
                                <Rectangle.RenderTransform>
                                    <CompositeTransform x:Name="BigCoverTransform" ScaleX="1" ScaleY="1"/>
                                </Rectangle.RenderTransform>
                                <Rectangle.Fill>
                                    <ImageBrush x:Name="BigCoverImage" Stretch="UniformToFill">
                                        <ImageBrush.RelativeTransform>
                                            <ScaleTransform CenterX="0.5" CenterY="0.5" ScaleX="1" ScaleY="1"/>
                                        </ImageBrush.RelativeTransform>
                                    </ImageBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                        </Grid>
                    </PivotItem>
                    <!-- Lyrics page -->
                    <PivotItem>
                        <Grid>
                            <ProgressBar x:Name="LyricsLoadingBar" IsIndeterminate="True" VerticalAlignment="Top" Visibility="Collapsed" Foreground="White"/>
                            <ScrollViewer x:Name="LyricsFallbackScrollViewer" Visibility="Collapsed" Margin="15,20,15,60" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                                <TextBlock x:Name="LyricsFallbackText" Text="Swipe to see lyrics..." Foreground="#B3B3B3" FontSize="16" TextWrapping="Wrap" TextAlignment="Left"/>
                            </ScrollViewer>
                            <ListView x:Name="LyricsListView" IsItemClickEnabled="True" ItemClick="LyricsListView_ItemClick" SelectionMode="None" Margin="10,0" ShowsScrollingPlaceholders="False" ContainerContentChanging="LyricsListView_ContainerContentChanging">
