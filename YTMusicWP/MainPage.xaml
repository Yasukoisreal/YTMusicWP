                                        <TranslateTransform x:Name="TitleTranslate" X="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Canvas>
                            <TextBlock x:Name="BigArtist" Text="Artist" FontSize="16" Foreground="#B3B3B3" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
