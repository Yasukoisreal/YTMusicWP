                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock x:Name="BigTitle" Text="Title" FontSize="24" FontWeight="Bold" Foreground="White" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="BigArtist" Text="Artist" FontSize="16" Foreground="#AAAAAA" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button x:Name="BigHeartBtn" Grid.Column="2" Content="♡" Click="HeartButton_Click" Style="{StaticResource IconButtonStyle}" Foreground="White" FontSize="32" Width="50" Height="50" Margin="5,0,0,0"/>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentTimeText" Text="00:00" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        <Slider x:Name="MusicSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="0" Margin="10,0" PointerCaptureLost="MusicSlider_PointerCaptureLost" PointerPressed="MusicSlider_PointerPressed" Foreground="#FFFFFF" Background="#555555" Style="{StaticResource ModernSliderStyle}"/>
                        <TextBlock x:Name="TotalTimeText" Text="00:00" Grid.Column="2" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Click="ShuffleButton_Click" Style="{StaticResource IconButtonStyle}">
                            <FontIcon x:Name="ShuffleIcon" FontFamily="Segoe UI Symbol" Glyph="&#xE14B;" Foreground="White" FontSize="20"/>
                        </Button>
                        <Button Grid.Column="1" Click="PrevButton_Click" Style="{StaticResource IconButtonStyle}">
                            <FontIcon FontFamily="Segoe UI Symbol" Glyph="&#xE100;" Foreground="White" FontSize="24"/>
                        </Button>
                        <Button Grid.Column="2" Click="PlayPauseButton_Click" Style="{StaticResource IconButtonStyle}" Width="64" Height="64" Margin="5,0,5,0">
                            <Border Background="White" CornerRadius="32" Width="64" Height="64">
                                <SymbolIcon x:Name="BigPlayIcon" Symbol="Play" Foreground="Black"/>
                            </Border>
                        </Button>
                        <Button Grid.Column="3" Click="NextButton_Click" Style="{StaticResource IconButtonStyle}">
                            <FontIcon FontFamily="Segoe UI Symbol" Glyph="&#xE101;" Foreground="White" FontSize="24"/>
                        </Button>
                        <Button Grid.Column="4" Click="RepeatButton_Click" Style="{StaticResource IconButtonStyle}">
                            <FontIcon x:Name="RepeatIcon" FontFamily="Segoe UI Symbol" Glyph="&#xE1CD;" Foreground="White" FontSize="20"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid x:Name="NowPlayingMenuDialog" Visibility="Collapsed" Canvas.ZIndex="250" Background="#A0000000" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Button Grid.Row="0" Click="CloseNowPlayingMenu_Click" Style="{StaticResource IconButtonStyle}" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            <Border Grid.Row="1" Background="#282828" CornerRadius="16,16,0,0" Padding="0,20,0,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="MenuTransform" Y="800"/>
                </Border.RenderTransform>
                <StackPanel>
                    <Grid Margin="20,0,20,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Width="50" Height="50" RadiusX="4" RadiusY="4">
                            <Rectangle.Fill>
                                <ImageBrush x:Name="MenuCoverImage" Stretch="UniformToFill">
                                    <ImageBrush.RelativeTransform>
                                        <ScaleTransform CenterX="0.5" CenterY="0.5" ScaleX="1.35" ScaleY="1.35"/>
                                    </ImageBrush.RelativeTransform>
                                </ImageBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                            <TextBlock x:Name="MenuTitle" Text="Title" FontSize="18" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="MenuArtist" Text="Artist" FontSize="14" Foreground="#AAAAAA" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                    <Rectangle Height="1" Fill="#333333" Margin="0,0,0,10"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="350">
                        <StackPanel>
                            <Button Click="MenuAddToPlaylistNowPlaying_Click" Style="{StaticResource IconButtonStyle}" Height="60" HorizontalContentAlignment="Stretch">
                                <Grid Margin="20,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" FontFamily="Segoe UI Symbol" Glyph="&#xE109;" Foreground="White" FontSize="22" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="Add to Playlist" FontSize="18" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                </Grid>
                            </Button>
                            <Button Click="MenuSleepTimerNowPlaying_Click" Style="{StaticResource IconButtonStyle}" Height="60" HorizontalContentAlignment="Stretch">
                                <Grid Margin="20,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" FontFamily="Segoe UI Symbol" Glyph="&#xE121;" Foreground="White" FontSize="22" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="Sleep timer" FontSize="18" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <TextBlock x:Name="MenuSleepTimerStatus" Grid.Column="2" Text="Off" FontSize="16" Foreground="#1DB954" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                            <Button Click="MenuShareNowPlaying_Click" Style="{StaticResource IconButtonStyle}" Height="60" HorizontalContentAlignment="Stretch">
                                <Grid Margin="20,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <SymbolIcon Grid.Column="0" Symbol="Send" Foreground="White" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="Share" FontSize="18" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                </Grid>
                            </Button>
                            <Button x:Name="NowPlayingDownloadBtn" Click="MenuDownloadNowPlaying_Click" Style="{StaticResource IconButtonStyle}" Height="60" HorizontalContentAlignment="Stretch">
                                <Grid Margin="20,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <SymbolIcon Grid.Column="0" Symbol="Download" Foreground="White" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="Download" FontSize="18" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                </Grid>
                            </Button>
                            <Button Click="CloseNowPlayingMenu_Click" Style="{StaticResource IconButtonStyle}" Height="60" Margin="0,10,0,10">
                                <TextBlock Text="Close" FontSize="18" Foreground="#AAAAAA" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="AddToPlaylistDialog" Visibility="Collapsed" Canvas.ZIndex="150" Background="#AA000000" Grid.RowSpan="2">
            <Border Background="#282828" CornerRadius="8" Width="300" MaxHeight="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                <StackPanel>
                    <TextBlock Text="Add to Playlist" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    <ListView x:Name="DialogPlaylistList" MaxHeight="250" IsItemClickEnabled="True" ItemClick="DialogPlaylistList_ItemClick" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="18" Foreground="White" Margin="0,12"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Content="Cancel" Click="CancelAddToPlaylist_Click" HorizontalAlignment="Stretch" Foreground="White" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
        <Grid x:Name="CreatePlaylistDialog" Visibility="Collapsed" Canvas.ZIndex="150" Background="#AA000000" Grid.RowSpan="2">
            <Border Background="#282828" CornerRadius="8" Width="300" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                <StackPanel>
                    <TextBlock Text="New Playlist" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    <TextBox x:Name="NewPlaylistNameTextBox" PlaceholderText="Playlist name..." Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="CancelCreatePlaylist_Click" Foreground="#AAAAAA" Margin="0,0,10,0"/>
                        <Button Content="Create" Click="ConfirmCreatePlaylist_Click" Foreground="#1DB954" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Grid x:Name="LoginWebContainer" Visibility="Collapsed" Canvas.ZIndex="300" Background="#121212" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#282828" Padding="15">
                <Grid>
                    <TextBlock Text="Google Sign-In" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="✕" Click="CloseLoginWeb_Click" Foreground="White" FontSize="20" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0" MinWidth="0"/>
                </Grid>
            </Border>
            <WebView x:Name="LoginWebView" Grid.Row="1" NavigationStarting="LoginWebView_NavigationStarting" NavigationCompleted="LoginWebView_NavigationCompleted" NavigationFailed="LoginWebView_NavigationFailed"/>
            <ProgressBar x:Name="LoginWebLoading" Grid.Row="1" VerticalAlignment="Top" IsIndeterminate="True" Foreground="#1DB954" Visibility="Collapsed"/>
        </Grid>
        <Border x:Name="ToastNotification" Canvas.ZIndex="200" Visibility="Collapsed" Background="#1DB954" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Padding="15" Margin="0,0,0,70" CornerRadius="4" Grid.RowSpan="2">
            <TextBlock x:Name="ToastText" Text="Message" Foreground="White" FontWeight="SemiBold" FontSize="14" TextAlignment="Center"/>
        </Border>
        <Border x:Name="DownloadStatusBar" Canvas.ZIndex="200" Visibility="Collapsed" Background="#1DB954" VerticalAlignment="Top" HorizontalAlignment="Stretch" Padding="15,10" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="DownloadStatusText" Text="Downloading..." Foreground="White" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" TextTrimming="CharacterEllipsis"/>
                <ProgressBar x:Name="DownloadProgressBar" Grid.Row="1" Minimum="0" Maximum="100" Value="0" Foreground="White" Background="#116D31"/>
            </Grid>
        </Border>
    </Grid>
</Page>