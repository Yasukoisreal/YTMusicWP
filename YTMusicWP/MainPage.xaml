                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" FontSize="{Binding FontSize}" Foreground="{Binding ColorBrush}" TextWrapping="Wrap" TextAlignment="Left" Margin="10,8" FontWeight="Bold" FontFamily="{StaticResource MontserratBold}" HorizontalAlignment="Left"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem"><Setter Property="HorizontalContentAlignment" Value="Stretch"/></Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                            <Rectangle Height="60" VerticalAlignment="Bottom" IsHitTestVisible="False">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                        <GradientStop Color="#121212" Offset="0"/>
                                        <GradientStop Color="#00121212" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,15" Canvas.ZIndex="10">
                                <Button Content="A-" Click="DecreaseLyricsSize_Click" FontSize="14" FontWeight="Bold" Foreground="White" Background="#33FFFFFF" BorderThickness="0" BorderBrush="Transparent" MinHeight="35" MinWidth="50" Padding="0" Margin="0,0,10,0"/>
                                <Button Content="A+" Click="IncreaseLyricsSize_Click" FontSize="14" FontWeight="Bold" Foreground="White" Background="#33FFFFFF" BorderThickness="0" BorderBrush="Transparent" MinHeight="35" MinWidth="50" Padding="0" Margin="0,0,10,0"/>
