                        </Grid>
                    </Button>
                    <Button Click="CloseBottomSheet_Click" Style="{StaticResource IconButtonStyle}" Height="55" Margin="0,5,0,15">
                        <TextBlock Text="Close" FontSize="17" Foreground="#B3B3B3" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold"/>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════ DIALOGS ═══════════════════════════════════ -->
        <Grid x:Name="AddToPlaylistDialog" Visibility="Collapsed" Canvas.ZIndex="150" Background="#AA000000" Grid.RowSpan="3">
            <Border Background="#252525" CornerRadius="16" Width="300" MaxHeight="400" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                <StackPanel>
                    <TextBlock Text="Add to Playlist" FontSize="18" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    <ListView x:Name="DialogPlaylistList" MaxHeight="250" IsItemClickEnabled="True" ItemClick="DialogPlaylistList_ItemClick" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="18" Foreground="White" Margin="0,12"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Content="Cancel" Click="CancelAddToPlaylist_Click" HorizontalAlignment="Stretch" Foreground="White" Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
        <Grid x:Name="CreatePlaylistDialog" Visibility="Collapsed" Canvas.ZIndex="150" Background="#AA000000" Grid.RowSpan="3">
            <Border Background="#252525" CornerRadius="16" Width="300" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="20">
                <StackPanel>
                    <TextBlock Text="New Playlist" FontSize="18" FontFamily="{StaticResource MontserratBold}" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                    <TextBox x:Name="NewPlaylistNameTextBox" PlaceholderText="Playlist name..." Style="{StaticResource DarkTextBoxStyle}" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="CancelCreatePlaylist_Click" Foreground="#B3B3B3" Margin="0,0,10,0"/>
                        <Button Content="Create" Click="ConfirmCreatePlaylist_Click" Foreground="#1DB954" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════ LOGIN WEB ═══════════════════════════════════ -->
        <Grid x:Name="LoginWebContainer" Visibility="Collapsed" Canvas.ZIndex="300" Background="#121212" Grid.RowSpan="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#282828" Padding="15">
                <Grid>
                    <TextBlock Text="Google Sign-In" Foreground="White" FontSize="18" FontFamily="{StaticResource MontserratSemiBold}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Content="✕" Click="CloseLoginWeb_Click" Foreground="White" FontSize="20" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0" MinWidth="0"/>
                </Grid>
            </Border>
            <WebView x:Name="LoginWebView" Grid.Row="1" NavigationStarting="LoginWebView_NavigationStarting" NavigationCompleted="LoginWebView_NavigationCompleted" NavigationFailed="LoginWebView_NavigationFailed"/>
            <ProgressBar x:Name="LoginWebLoading" Grid.Row="1" VerticalAlignment="Top" IsIndeterminate="True" Foreground="#1DB954" Visibility="Collapsed"/>
        </Grid>

        <!-- ═══════════════════════════════════ TOAST ═══════════════════════════════════ -->
        <Border x:Name="ToastNotification" Canvas.ZIndex="200" Visibility="Collapsed" Background="#1DB954" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Padding="14,10" Margin="15,0,15,75" CornerRadius="12" Grid.RowSpan="3">
            <TextBlock x:Name="ToastText" Text="Message" Foreground="White" FontFamily="{StaticResource MontserratSemiBold}" FontWeight="SemiBold" FontSize="14" TextAlignment="Center"/>
        </Border>

        <!-- ═══════════════════════════════════ DOWNLOAD STATUS ═══════════════════════════════════ -->
        <Border x:Name="DownloadStatusBar" Canvas.ZIndex="200" Visibility="Collapsed" Background="#1DB954" VerticalAlignment="Top" HorizontalAlignment="Stretch" Padding="15,10" Margin="0,0,0,0" Grid.RowSpan="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="DownloadStatusText" Text="Downloading..." Foreground="White" FontFamily="{StaticResource MontserratSemiBold}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" TextTrimming="CharacterEllipsis"/>
                <ProgressBar x:Name="DownloadProgressBar" Grid.Row="1" Minimum="0" Maximum="100" Value="0" Foreground="White" Background="#116D31"/>
            </Grid>
        </Border>
    </Grid>
</Page>
